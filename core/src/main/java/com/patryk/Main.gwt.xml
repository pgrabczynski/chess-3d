<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC "-//Google Inc.//DTD Google Web Toolkit 2.11.0//EN"
        "https://www.gwtproject.org/doctype/2.11.0/gwt-module.dtd">

<module rename-to="html">

    <!-- CORE GAME -->
    <source path="com" />

    <!-- LibGDX backend -->
    <inherits name="com.badlogic.gdx.backends.gdx_backends_gwt" />

    <!-- Optional: reflection support -->
    <extend-configuration-property name="gdx.reflect.include" value="*" />

</module>
